rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ngo_staff'
        )
      ); 
    }
    function isApproved() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS
    // -------------------------------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.email is string 
          && data.displayName is string && data.displayName.size() < 100
          && data.role in ['donor', 'volunteer', 'beneficiary', 'ngo_partner', 'member', 'moderator', 'admin', 'super_admin', 'ngo_staff', 'csr', 'strategic_partner']
          && data.status in ['pending', 'approved', 'rejected', 'suspended', 'under_review'];
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && isOwner(userId) 
        && isValidUser(incoming())
        && incoming().status == 'pending'
        && incoming().role in ['member', 'donor', 'volunteer', 'beneficiary', 'ngo_partner', 'csr', 'ngo_staff']; // Users can't create themselves as admin
        
      allow update: if isSignedIn() && (
        isAdmin() || (
          isOwner(userId) && (
            // User can update their own profile info but NOT their role or status
            incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'phoneNumber', 'reputation', 'skills', 'location', 'profession'])
          )
        )
      );
    }

    // -------------------------------------------------------------------------
    // NGO PROFILES
    // -------------------------------------------------------------------------
    match /ngo_profiles/{ngoId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().approvalStatus == 'pending';
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // BENEFICIARY REQUESTS
    // -------------------------------------------------------------------------
    match /beneficiary_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.beneficiaryId == request.auth.uid);
      allow create: if isSignedIn() && isApproved() && incoming().beneficiaryId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && isOwner(resource.data.beneficiaryId) && incoming().diff(existing()).affectedKeys().hasOnly(['description']));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // VOLUNTEER TASKS
    // -------------------------------------------------------------------------
    match /volunteer_tasks/{taskId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.volunteerId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.volunteerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // AID APPLICATIONS
    // -------------------------------------------------------------------------
    match /aid_applications/{aidId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.beneficiaryId == request.auth.uid);
      allow create: if isSignedIn() && isApproved() && incoming().beneficiaryId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // UPDATES
    // -------------------------------------------------------------------------
    match /updates/{updateId} {
      function isValidUpdate(data) {
        return data.content is string && data.content.size() <= 5000
          && data.authorId == request.auth.uid
          && data.createdAt == request.time;
      }

      allow read: if true;
      allow create: if isSignedIn() && isApproved() && isValidUpdate(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || (
          isOwner(existing().authorId) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['content', 'imageUrl'])
        ) || (
          // Allow users to like
          incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'likedBy'])
          && incoming().likesCount == existing().likesCount + 1
        )
      );
      allow delete: if isAdmin() || isOwner(existing().authorId);
    }

    // -------------------------------------------------------------------------
    // CAMPAIGNS & EVENTS
    // -------------------------------------------------------------------------
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // COLLABORATIONS
    // -------------------------------------------------------------------------
    match /collaborations/{collabId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.ngoId == request.auth.uid);
      allow create: if isSignedIn() && incoming().ngoId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // COMMENTS
    // -------------------------------------------------------------------------
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    // -------------------------------------------------------------------------
    // REPORTED UPDATES
    // -------------------------------------------------------------------------
    match /reported_updates/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ACTIVITIES
    // -------------------------------------------------------------------------
    match /activities/{activityId} {
       allow read: if true;
       allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
       allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // DONATIONS
    // -------------------------------------------------------------------------
    match /donations/{donationId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.donorId == request.auth.uid);
      allow create: if (incoming().donorId == null || isOwner(incoming().donorId))
        && incoming().amount > 0
        && incoming().createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // NOTIFICATIONS
    // -------------------------------------------------------------------------
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
      allow create: if isAdmin() || (isSignedIn() && incoming().type == 'alert');
    }
  }
}
